rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 러너 네임 변경 전파 — 이름을 바꾸면 과거 글·참석·러닝·댓글의 작성자명도 함께 갱신된다
    // (crew.ts renameAuthor). 작성자가 name 문자열로 박제되는 스키마라 필요한 예외.
    // **name 필드 하나만 바뀌는 수정**으로 한정 → 본문·거리·이미지 등 내용 변조는 여전히 차단.
    // ⚠ 단 소유검증이 없어, '아무 문서의 작성자명을 임의 문자열로' 바꾸는 것 자체(사칭)는 규칙만으론 못 막는다.
    //    delete 개방과 같은 등급의 pre-Auth 트레이드오프 — Auth 도입 시 uid 소유검증으로 교체.
    function isRenameOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name'])
             && request.resource.data.name is string
             && request.resource.data.name.size() <= 40;
    }

    // 친목용: 누구나 읽기. 생성은 타입·크기 검증으로 도배/오염 방지.
    // ⚠ 인증(Firebase Auth) 도입 전까지 delete는 소유 검증이 불가능하다.
    //    delete 버튼(방명록·갤러리·참석취소·러닝)을 살리려면 전면 허용이 유일한 방법이므로,
    //    비정상 클라이언트(REST 스크립트 등)의 대량삭제·도배는 App Check(Play Integrity/reCAPTCHA)로 차단하는 것을 전제로 한다.
    //    (P5 자문 게이트: 곽재원·천도윤 공통 권고 — Auth 도입 시 소유 기반 delete로 교체)
    match /guestbook/{id} {
      allow read: if true;
      allow create: if request.resource.data.name is string
                    && request.resource.data.name.size() <= 20
                    && request.resource.data.msg is string
                    && request.resource.data.msg.size() <= 200;
      // 본인 글 수정(msg만) 또는 러너 네임 전파(name만)로 한정.
      // → 임의 필드 주입·용량 부풀리기(생성 제한 우회)를 차단(diff().hasOnly).
      allow update: if isRenameOnly()
                    || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['msg'])
                        && request.resource.data.msg is string
                        && request.resource.data.msg.size() <= 200);
      allow delete: if true;
    }
    match /gallery/{id} {
      allow read: if true;
      allow create: if request.resource.data.image is string
                    && request.resource.data.image.size() < 1000000
                    && request.resource.data.image.matches('data:image/.*'); // 실제 이미지 data URI만 — src="" XSS 주입 차단
      allow update: if isRenameOnly();   // 러너 네임 변경 전파만
      allow delete: if true;
    }
    match /attendance/{id} {
      allow read: if true;
      allow create: if request.resource.data.name is string
                    && request.resource.data.name.size() <= 40;
      allow update: if isRenameOnly();   // 러너 네임 변경 전파만
      allow delete: if true;   // 참석 취소 토글(remove)
    }
    // 러닝 기록(웹·앱·워치 공용). 결정적 id로 멱등 upsert(create+update=merge).
    // distanceKm 범위 검증으로 today 합산·리더보드 통계 오염 방지(천도윤 #4).
    match /runs/{id} {
      allow read: if true;
      allow create: if request.resource.data.name is string
                    && request.resource.data.name.size() <= 40
                    && request.resource.data.distanceKm is number
                    && request.resource.data.distanceKm >= 0
                    && request.resource.data.distanceKm <= 500;
      // 기존 기록 update는 **distanceKm·kind 변경 금지** → 남의 기록을 0으로 지우거나 부풀려
      // today 합산·리더보드를 오염시키는 공격 차단. kind를 막는 이유: 남의 러닝에 'walk'를 심으면
      // 랭킹·배지 집계(lib/stats는 걷기를 뺀다)에서 그 사람을 통째로 지워버릴 수 있다.
      // 정상 경로(멱등 재저장·러너 네임 전파)는 둘 다 안 바꾸므로 통과.
      // kind 없는 과거 문서는 'run'으로 간주 — 재동기화 시 우리 코드도 'run'이면 필드를 안 적는다.
      // (작성자명 재지정까지 막으려면 Auth 소유검증 필요 — pre-Auth 한계)
      // update는 distanceKm·kind·**durationSec**을 불변으로 강제한다.
      // durationSec을 뺐던 게 구멍이었다: 페이스 통계(stats.avgPace)·상세 페이스가 전부 duration
      // 기반이라, 남의 러닝 durationSec을 1로 바꾸면 그 사람 평균 페이스가 괴물이 되고 크루 통계가
      // 오염된다(distanceKm만 막아 절반만 방어했던 셈). 정상 경로(멱등 재저장·개명 전파)는 duration을
      // 안 바꾸므로 통과. **거리·시간·종목이 실제로 달라지는 재동기화는 delete→재생성으로 우회**(run.ts).
      allow update: if request.resource.data.name is string
                    && request.resource.data.name.size() <= 40
                    && request.resource.data.distanceKm is number
                    && request.resource.data.distanceKm == resource.data.distanceKm
                    && request.resource.data.get('durationSec', 0) == resource.data.get('durationSec', 0)
                    && request.resource.data.get('kind', 'run') == resource.data.get('kind', 'run');
      allow delete: if true;   // 러닝 기록 삭제 버튼(explore.tsx) + 재동기화 우회(run.ts)
    }
    // 댓글 — 러닝 기록·방명록 등에 달리는 코멘트. parentId로 묶임.
    match /comments/{id} {
      allow read: if true;
      allow create: if request.resource.data.parentId is string
                    && request.resource.data.name is string
                    && request.resource.data.name.size() <= 40
                    && request.resource.data.msg is string
                    && request.resource.data.msg.size() <= 200;
      allow update: if isRenameOnly();   // 러너 네임 변경 전파만
      allow delete: if true;
    }
    // 크루 모임 일정. 아무나 생성(친목 수준 — pre-Auth. delete 개방과 같은 등급).
    // startAt(모임 시각) 필수·타입검증으로 오염 방지. update는 러너 네임 전파만(제목·날짜 변조 차단).
    match /events/{id} {
      allow read: if true;
      allow create: if request.resource.data.title is string
                    && request.resource.data.title.size() <= 40
                    && request.resource.data.desc is string
                    && request.resource.data.desc.size() <= 200
                    && request.resource.data.startAt is number
                    && request.resource.data.startAt > 0;
      allow update: if isRenameOnly();
      allow delete: if true;   // 모임 취소·정리
    }
    // 앱 출시 알림 대기자(이메일). 열람 차단 — 관리자만 Firebase 콘솔에서 조회.
    // (곽재원 Blocker #1·천도윤 #2 공통: 이메일 하베스팅 차단)
    match /waitlist/{id} {
      allow read: if false;
      allow create: if request.resource.data.email is string
                    && request.resource.data.email.size() <= 320;
      allow update, delete: if false;
    }
  }
}
